      "position": [416, 0],
      "id": "a96ae1ec-65a4-427f-bb85-98997cb04f94",
      "name": "Calculate Time Window"
    },
    {
      "parameters": {
        "url": "https://YOUR_CONTROLLER_URL/apis/dashboard.envmgmt.io/v1/events/paas/partner/kind/compute/instance",
        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            {
              "name": "range_from",
              "value": "={{ $json.range_from }}"
            },
            {
              "name": "range_to",
              "value": "={{ $json.range_to }}"
            },
            {
              "name": "limit",
              "value": "30"
            }
          ]
        },
        "options": {
          "allowUnauthorizedCerts": true,
          "pagination": {
            "pagination": {
              "parameters": {
                "parameters": [
                  {
                    "name": "offset",
                    "value": "={{ $pageCount*30 }}"
                  }
                ]
              },
              "paginationCompleteWhen": "other",
              "completeExpression": "={{ $response.body.offset + $response.body.limit >= $response.body.count }}"
            }
          }
        }
      },
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
      "position": [660, 0],
      "id": "aa5d7665-5d3e-45c4-8d17-274c9cdab01e",
