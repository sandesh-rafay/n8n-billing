      "id": "d2e9e62a-38e6-4ca9-bf9a-ccd63245e778",
      "name": "Filter Billable Events"
    },
    {
      "parameters": {
        "jsCode": "__FORWARD_EVENTS__"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1100, 0],
      "id": "aa83e96e-6a69-4018-9335-0710bf5ca637",
      "name": "Forward Events to Billing Workflow"
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "INSERT INTO n8n_billing_state (key, value) VALUES ('previous_run', '{{ $(\"Calculate Time Window\").first().json.range_to }}') ON CONFLICT (key) DO UPDATE SET value = EXCLUDED.value"
      },
      "type": "n8n-nodes-base.postgres",
